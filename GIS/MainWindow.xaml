<Window x:Class="GIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS"
        mc:Ignorable="d"
        Title="GIS" Height="720" Width="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Background="AntiqueWhite">
            <Grid.RowDefinitions>
                <RowDefinition Height="40*"></RowDefinition>
                <RowDefinition Height="60*"></RowDefinition>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="10" Background="Wheat">
                <Button Name="LoadFileButton" Margin="10" Width="Auto" Height="40" Content="Загрузить" FontSize="20" Click="LoadFileButton_Click"/>
            </StackPanel>

            <ListBox x:Name="LayerListBox" Grid.Row="1" Grid.Column="0" Margin="10" Background="Wheat" MouseDoubleClick="LayerListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Name}" 
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>


                            <Button x:Name="LayerSettingsButton"
                                    Grid.Column="5"
                                    Tag="{Binding}"
                                    Content="⚙"
                                    FontSize="14"
                                    Width="24"
                                    Height="24"
                                    ToolTip="Настройки слоя" 
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" Click="LayerSettingsButton_Click"/>

                            <Button x:Name="LayerTableButton"
                                    Grid.Column="4"
                                    Tag="{Binding}"
                                    Content="📋"
                                    FontSize="14"
                                    Width="24"
                                    Height="24"
                                    ToolTip="Настройки слоя" 
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" Click="LayerTableButton_Click"/>

                            <Button x:Name="LayerZIndexUp"
                                    Grid.Column="2"
                                    Content=" ↑ "/>
                            <Button x:Name="LayerZIndexDown"
                                    Grid.Column="3"
                                    Content=" ↓ "/>
                            <!-- TODO: Организовать Z-index -->
                           
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <StatusBar Grid.Row="1" Grid.Column="1">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBox" Text="Готов к использованию"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="CoordinatesTextBox" Text="Координаты: 0, 0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ScaleTextBox" Text="Масштаб: 1:5000"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="BoundsCenterTextBox" Text="Границ пока нет"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="BoundsSizeTextBox" Text="Границ пока нет"/>
            </StatusBarItem>
        </StatusBar>

        <Canvas x:Name="MapCanvas" Grid.Row="0" Grid.Column="1" Margin="10" Background="#FFE6D9D4" MouseMove="MapCanvas_MouseMove" MouseDown="MapCanvas_MouseDown" MouseWheel="MapCanvas_MouseWheel" ClipToBounds="True"/>
    </Grid>
</Window>
