<Window x:Name="OnClosed" x:Class="GIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS"
        xmlns:classes="clr-namespace:GIS.Classes.Main"
        mc:Ignorable="d"
        Title="GIS" Height="768" Width="1366">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#4A90D9"/>
                                <Setter Property="BorderBrush" Value="#2C6BA0"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="RadioButton" x:Key="MapStyleRadio">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#4A90D9"/>
                                <Setter Property="BorderBrush" Value="#2C6BA0"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="MapStyleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Background="AntiqueWhite">
            <Grid.RowDefinitions>
                <RowDefinition Height="70*"></RowDefinition>
                <RowDefinition Height="40*"></RowDefinition>
            </Grid.RowDefinitions>

            <StackPanel Margin="5" Background="Wheat">
                <GroupBox Header="Файл" Margin="0,0,0,5" Padding="2">
                    <StackPanel>
                        <Button Name="LoadFileButton" Content="Загрузить слой" Click="LoadFileButton_Click" Height="28" Margin="2"/>
                        <Button Name="CreateLayerButton" Content="Создать слой" Click="CreateLayerButton_Click" Height="28" Margin="2"/>
                        <Button Name="ImportImageButton" Content="Импортировать фото" Click="ImportImageButton_Click" Height="28" Margin="2"/>
                        <Button Name="SaveLayerButton" Content="Сохранить слой" Click="SaveLayerButton_Click" Height="28" Margin="2"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Анализы" Margin="0,0,0,5" Padding="2">
                    <StackPanel>
                        <Button Name="BufferAnalysisButton" Content="Буфер" Click="BufferAnalysisButton_Click" Height="28" Margin="2"/>
                        <Button Name="SpatialQueryButton" Content="Пространственная выборка" Click="SpatialQueryButton_Click" Height="28" Margin="2"/>
                        <Button Name="AttributeQueryButton" Content="Атрибутивный запрос" Click="AttributeQueryButton_Click" Height="28" Margin="2"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Подложка" Margin="0,0,0,5" Padding="2">
                    <WrapPanel HorizontalAlignment="Center">
                        <RadioButton x:Name="StreetMapRadio" Content="🗺️" ToolTip="Уличная карта" 
                     GroupName="MapLayer" Tag="Street"
                     Checked="MapLayerRadio_Checked" Width="40" Height="30" Margin="2" Style="{StaticResource MapStyleRadio}"/>
                        <RadioButton x:Name="SatelliteRadio" Content="🛰️" ToolTip="Спутник" 
                     GroupName="MapLayer" Tag="Satellite"
                     Checked="MapLayerRadio_Checked" Width="40" Height="30" Margin="2" Style="{StaticResource MapStyleRadio}"/>
                        <RadioButton x:Name="NoMapRadio" Content="❌" ToolTip="Нет подложки" 
                     GroupName="MapLayer" Tag="None"
                     Checked="MapLayerRadio_Checked" Width="40" Height="30" Margin="2" Style="{StaticResource MapStyleRadio}" Cursor="Hand"/>
                    </WrapPanel>
                </GroupBox>

                <GroupBox Header="Инструменты" Margin="0,0,0,5" Padding="2">
                    <WrapPanel HorizontalAlignment="Center">
                        <RadioButton x:Name="MoveRadio" Content="🖱️" ToolTip="Перемещение" GroupName="Tools" IsChecked="True"
                         Click="MapModeRadioButton_Click" Tag="Move" Width="40" Height="30" Margin="2"/>
                        <RadioButton x:Name="SelectRadio" Content="🔲" ToolTip="Выделение" GroupName="Tools"
                         Click="MapModeRadioButton_Click" Tag="Select" Width="40" Height="30" Margin="2"/>
                        <RadioButton x:Name="DrawRadio" Content="✏️" ToolTip="Рисование" GroupName="Tools"
                         Click="MapModeRadioButton_Click" Tag="Draw" Width="40" Height="30" Margin="2"/>
                        <RadioButton x:Name="RulerRadio" Content="📏" ToolTip="Линейка" GroupName="Tools"
                         Click="MapModeRadioButton_Click" Tag="Ruler" Width="40" Height="30" Margin="2"/>
                        <RadioButton x:Name="AreaRadio" Content="📐" ToolTip="Площадь" GroupName="Tools"
                         Click="MapModeRadioButton_Click" Tag="Area" Width="40" Height="30" Margin="2"/>
                    </WrapPanel>
                </GroupBox>
            </StackPanel>

            <TreeView x:Name="LayerTreeView" Grid.Row="1" Margin="10" Background="Wheat" Padding="0"
                       HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="LayerListBox_MouseDoubleClick" 
                      KeyDown="LayerListBox_KeyDown" SelectedItemChanged="LayerTreeView_SelectedItemChanged">
                
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <!-- <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/> -->
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Tag" Value="{Binding}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowInTree}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.Resources>
                    <ContextMenu x:Key="LayerContextMenu">
                    </ContextMenu>
                    
                    
                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Width" Value="24"/>
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>



                    <HierarchicalDataTemplate DataType="{x:Type classes:Layer}" ItemsSource="{Binding ObjectList}">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>    
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Name}" 
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                            <Button x:Name="LayerZIndexUp"
                                    Grid.Column="2"
                                    Content=" ↑ " 
                                    CommandParameter="{Binding}"
                                    Click="LayerZIndexUp_Click"/>

                            <Button x:Name="LayerZIndexDown"
                                    Grid.Column="3"
                                    Content=" ↓ "
                                    CommandParameter="{Binding}"
                                    Click="LayerZIndexDown_Click"/>

                            <Button x:Name="LayerTableButton"
                                    Grid.Column="4"
                                    Tag="{Binding}"
                                    Content="📋"
                                    ToolTip="Настройки слоя" 
                                    Click="LayerTableButton_Click"/>

                            <Button x:Name="LayerSettingsButton"
                                    Grid.Column="5"
                                    Tag="{Binding}"
                                    Content="⚙"
                                    ToolTip="Настройки слоя"                                   
                                    Click="LayerSettingsButton_Click"/>
                        </Grid>
                    </HierarchicalDataTemplate>

                    <HierarchicalDataTemplate DataType="{x:Type classes:Feature}">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>

                            <Button Grid.Column="1" Content="⚙"/>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Grid>

        <StatusBar Grid.Row="1" Grid.Column="1">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBox" Text="Готов к использованию"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="CoordinatesTextBox" Text="Координаты: 0, 0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ScaleTextBox" Text="Масштаб: 1:5000"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="MouseGeoCoordsTextBox" Text="Границ пока нет"/>
            </StatusBarItem>
        </StatusBar>
        
        <Grid Grid.Row="0" Grid.Column="1">
            <Canvas x:Name="MapCanvas" Margin="10" Background="#FFE6D9D4" MouseMove="MapCanvas_MouseMove" MouseDown="MapCanvas_MouseDown" MouseWheel="MapCanvas_MouseWheel" ClipToBounds="True" KeyDown="MapCanvas_KeyDown" MouseUp="MapCanvas_MouseUp" Loaded="MapCanvas_Loaded" MouseLeave="MapCanvas_MouseLeave" Focusable="True"/>
            
            <Grid x:Name="FeaturePropertiesGrid" Visibility="Hidden">
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="White">
                    <TextBlock Text="Свойства фигуры" HorizontalAlignment="Center" FontSize="16" Padding="10"/>
                    <DataGrid x:Name="FeaturePropertiesDataGrid" Margin="10" IsReadOnly="True" Background="Transparent" BorderThickness="1"
                              FontFamily="Arial" FontSize="16" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserResizeColumns="False" 
                              CanUserSortColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" 
                              GridLinesVisibility="All" HeadersVisibility="Column" MaxHeight="400">
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Атрибут" Binding="{Binding Key}" Width="Auto" MinWidth="100"/>
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="Auto"/>
                        </DataGrid.Columns>

                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="MinHeight" Value="30"/>
                            </Style>

                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>
</Window>
