<UserControl x:Class="GIS.UserControls.ColorPickerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GIS.Classes.Converters"
             x:Name="ColorPickerRoot">

    <UserControl.Resources>
        <converters:ColorToHexConverter x:Key="ColorToHexConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="ColorPreview"
                Grid.Column="0" 
                Width="35" 
                Height="35" 
                CornerRadius="3"
                BorderBrush="DarkGray" 
                BorderThickness="1"
                Cursor="Hand"
                MouseDown="ColorPreview_MouseDown"
                ToolTip="Нажмите для выбора цвета"/>

        <TextBox x:Name="HexTextBox"
                 Grid.Column="1" 
                 Text="{Binding SelectedColor, ElementName=ColorPickerRoot, 
                        Converter={StaticResource ColorToHexConverter}, 
                        UpdateSourceTrigger=PropertyChanged}"
                 Margin="5,0,0,0"
                 VerticalAlignment="Center"
                 FontFamily="Consolas"
                 FontSize="13"/>

        <!-- Попап с расширенным выбором цвета -->
        <Popup x:Name="ColorPopup" 
               StaysOpen="True"
               PlacementTarget="{Binding ElementName=ColorPreview}"
               Placement="Bottom"
               AllowsTransparency="True"
               PopupAnimation="Fade">

            <Border Background="White" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="10">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel Width="220">
                    <TextBlock Text="Выбор цвета" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>

                    <Border x:Name="PreviewColor"
                            Height="30" 
                            CornerRadius="3"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Margin="0,0,0,10"/>

                    <!-- Палитра предустановленных цветов -->
                    <TextBlock Text="Палитра:" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <WrapPanel x:Name="ColorsPalette" 
                               Width="200"
                               Margin="0,0,0,10">
                        <!-- Цвета будут добавлены в коде -->
                    </WrapPanel>

                    <Separator Margin="0,5,0,10"/>

                    <!-- RGB слайдеры -->
                    <TextBlock Text="RGB:" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <!-- Красный -->
                    <StackPanel Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="R:" Foreground="#FF4444" FontWeight="Bold"/>
                            <Slider x:Name="RedSlider" 
                                    Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255" 
                                    Value="{Binding SelectedColor.R, ElementName=ColorPickerRoot, Mode=TwoWay}"
                                    Margin="5,0"
                                    Foreground="#FF4444" ValueChanged="Slider_ValueChanged"/>
                            <TextBlock x:Name="RedValue" Grid.Column="2" Text="{Binding Value, ElementName=RedSlider, StringFormat={}{0:F0}}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Зелёный -->
                    <StackPanel Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="G:" Foreground="#44AA44" FontWeight="Bold"/>
                            <Slider x:Name="GreenSlider" 
                                    Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255" 
                                    Value="{Binding SelectedColor.G, ElementName=ColorPickerRoot, Mode=TwoWay}"
                                    Margin="5,0" ValueChanged="Slider_ValueChanged"/>
                            <TextBlock x:Name="GreenValue" Grid.Column="2" Text="{Binding Value, ElementName=GreenSlider, StringFormat={}{0:F0}}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Синий -->
                    <StackPanel Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="B:" Foreground="#4444FF" FontWeight="Bold"/>
                            <Slider x:Name="BlueSlider" 
                                    Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255" 
                                    Value="{Binding SelectedColor.B, ElementName=ColorPickerRoot, Mode=TwoWay}"
                                    Margin="5,0" ValueChanged="Slider_ValueChanged"/>
                            <TextBlock x:Name="BlueValue" Grid.Column="2" Text="{Binding Value, ElementName=BlueSlider, StringFormat={}{0:F0}}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="OK" 
                                Width="60" 
                                Height="28"
                                Click="OkButton_Click"
                                Margin="0,0,5,0"/>
                        <Button Content="Отмена" 
                                Width="60" 
                                Height="28"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>