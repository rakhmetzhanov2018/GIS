<Window x:Class="GIS.Windows.DrawnObjectPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Свойства объекта" Height="Auto" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" MaxHeight="300" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AttributeFields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding Name}" Width="120" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Value}" Width="200" Margin="5,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Создать" Command="{Binding CreateCommand}" Width="80" Margin="5" IsDefault="True"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="80" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>