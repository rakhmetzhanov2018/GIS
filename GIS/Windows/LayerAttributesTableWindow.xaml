<Window x:Class="GIS.LayerAttributesTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS"
        mc:Ignorable="d"
        Title="Таблица объектов и их атрибутов" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <DataGrid x:Name="LayerItemsDataGrid" AutoGenerateColumns="True" Margin="10" IsReadOnly="True" EnableColumnVirtualization="True"/>
    </Grid>
</Window>
