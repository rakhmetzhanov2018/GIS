<Window x:Class="GIS.Windows.CreateNewLayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS.Windows"
        mc:Ignorable="d"
        Title="CreateNewLayerWindow" Height="620" Width="500" UseLayoutRounding="True" SnapsToDevicePixels="True" WindowStyle="ThreeDBorderWindow" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Arial"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="40"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название слоя:"/>
        <TextBox x:Name="LayerNameTextBox" Text="{Binding LayerName, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="0" Grid.Column="1"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип геометрии:"/>
        <ComboBox x:Name="GeometryTypeComboBox" Text="{Binding GeoType, UpdateSourceTrigger=PropertyChanged}"
                  Grid.Row="1" Grid.Column="1" SelectedIndex="0" Margin="5" HorizontalAlignment="Left" MinWidth="100">
            <ComboBoxItem Content="Point"/>
            <ComboBoxItem Content="LineString"/>
            <ComboBoxItem Content="Polygon"/>
        </ComboBox>

        <Border Grid.Row="2" Grid.ColumnSpan="2" CornerRadius="12" BorderThickness="1" 
                BorderBrush="Black" Background="#FFFFF8EB" Margin="0,20,0,0" Padding="5">
            <Grid Margin="5" VerticalAlignment="Center">
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Trebuchet MS"/>
                        <Setter Property="Margin" Value="0 10 0 0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="10 0 0 0"/>
                    </Style>
                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Content="Создание атрибутов объекта" FontFamily="Trebuchet MS"
                       Grid.ColumnSpan="2" FontSize="16"/>

                <TextBlock Grid.Row="1" Text="Имя атрибута:"/>
                <TextBox x:Name="AttributeNameTextBox" Text="{Binding NewAttributeName, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="1" Grid.Column="1" Padding="3,3,3,3"/>

                <TextBlock Grid.Row="2" Text="Тип атрибута:"/>
                <ComboBox x:Name="AttributeTypeComboBox" Text="{Binding NewAttributeType, UpdateSourceTrigger=PropertyChanged}" 
                          Grid.Row="2" Grid.Column="1" Margin="5" SelectedIndex="0">
                    <ComboBoxItem Content="Integer"/>
                    <ComboBoxItem Content="Double"/>
                    <ComboBoxItem Content="String"/>
                </ComboBox>

                <TextBlock Grid.Row="3" Text="Значение по умолчанию:"/>
                <TextBox x:Name="DefaultValueTextBox" Text="{Binding NewAttributeDefaultValue, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="3" Grid.Column="1" Padding="3,3,3,3"/>

                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                    <Button x:Name="AddAttributeButton" Command="{Binding AddAttributeCommand}"
                            HorizontalAlignment="Left" Content="Добавить новый артибут" FontSize="12" Width="Auto" Padding="5,5,5,5"/>
                    <Button x:Name="DeleteSelectedAttribureButton" Command="{Binding RemoveSelectedAttributeCommand}"
                            HorizontalAlignment="Right" Content="Удалить выбранный атрибут" FontSize="12" Width="Auto" Padding="5,5,5,5"/>
                </Grid>

                <DataGrid x:Name="AttributesDataGrid" Grid.Row="5" Grid.ColumnSpan="2" ItemsSource="{Binding Attributes}" SelectedItem="{Binding SelectedAttribute}"
                          FontFamily="Arial" FontSize="12" Height="200" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Имя атрибута" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Тип атрибута" Binding="{Binding DataType}"/>
                        <DataGridTextColumn Header="Значение по умолчанию" Binding="{Binding DefaultValue}"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>

        <Button x:Name="CreateLayer_CancelButton" Command="{Binding CancelCommand}"
                Grid.Row="3" Grid.Column="0" Content="Отменить" MinWidth="100" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
        <Button x:Name="CreateLayer_ApplyButton" Command="{Binding ApplyCommand}"
                Grid.Row="3" Grid.Column="1" Content="Применить" MinWidth="100" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Window>
