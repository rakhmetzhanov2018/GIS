<Window x:Class="GIS.Windows.LayerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS.Windows"
        xmlns:converters="clr-namespace:GIS.Classes.Converters"
        xmlns:controls="clr-namespace:GIS.UserControls"
        mc:Ignorable="d"
        Title="LayerSettingsWindow" Height="Auto" MaxWidth="500" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <DataTemplate x:Key="PointSettings">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Размер точки:"/>
                <TextBox Grid.Column="1" Text="{Binding PointSize, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="LineStringSettings">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Ширина линии:"/>
                <TextBox Grid.Column="1" Text="{Binding LineThickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PolygonSettings">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ширина линии:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LineThickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Цвет заполнения:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FillColor, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Arial"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>

            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название слоя:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LayerName}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Видимость слоя:"/>
        <CheckBox Grid.Row="1" Grid.Column="1" Margin="5" IsChecked="{Binding IsLayerVisible}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Прозрачность слоя:"/>
        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Opacity}" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Цвет:"/>
        <controls:ColorPickerUserControl Grid.Row="3" Grid.Column="1" 
                                  SelectedColor="{Binding MainColor, Mode=TwoWay}"
                                  Margin="5"/>

        <GroupBox Grid.Row="4" Grid.ColumnSpan="2" Header="Специфичные настройки" FontSize="14" Margin="0,10,0,10">
            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPointType}" Value="True">
                                <Setter Property="ContentTemplate" 
                                Value="{StaticResource PointSettings}"/>
                            </DataTrigger>
                            
                            <DataTrigger Binding="{Binding IsLineType}" Value="True">
                                <Setter Property="ContentTemplate" 
                                Value="{StaticResource LineStringSettings}"/>
                            </DataTrigger>
                            
                            <DataTrigger Binding="{Binding IsPolygonType}" Value="True">
                                <Setter Property="ContentTemplate" 
                                Value="{StaticResource PolygonSettings}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </GroupBox>

        <controls:FeatureAttributesCreationUserControl 
            Grid.Row="5" Grid.ColumnSpan="2"
            ViewModel="{Binding}" Margin="0,10,0,0"/>


        <Button x:Name="LayerSettingsCancelButton" Grid.Row="7" Grid.Column="0" Content="Отменить" MinWidth="100" VerticalAlignment="Bottom" HorizontalAlignment="Left" Command="{Binding CancelCommand}"/>
        <Button x:Name="LayerSettingsApplyButton" Grid.Row="7" Grid.Column="1" Content="Применить" MinWidth="100" VerticalAlignment="Bottom" HorizontalAlignment="Right" Command="{Binding ApplyCommand}"/>
    </Grid>
</Window>
