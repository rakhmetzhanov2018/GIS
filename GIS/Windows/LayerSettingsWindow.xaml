<Window x:Class="GIS.Windows.LayerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GIS.Windows"
        mc:Ignorable="d"
        Title="LayerSettingsWindow" Height="450" Width="400">
    <Grid>
        <Grid Margin="20">
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="Arial"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>

                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="10,0,0,10"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название слоя:"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Видимость слоя:"/>
            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding IsVisible, Mode=TwoWay}"/>
            
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Цвет:"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Color}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Размер точки:"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PointSize}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ширина линии:"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding StrokeSize}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Цвет заполнения:"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding FillColor}"/> 
            
        </Grid>
    </Grid>
</Window>
